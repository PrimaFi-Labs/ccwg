# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Starknet RPC (required for oracle + settlement)
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_KEY
NEXT_PUBLIC_CARTRIDGE_RPC=https://api.cartridge.gg/x/starknet/sepolia

# Server account for on-chain settlement (required for settlement)
SERVER_ACCOUNT_PRIVATE_KEY=0x...
SERVER_ACCOUNT_ADDRESS=0x...

# WebSocket port (default: 3001)
WS_PORT=3001
